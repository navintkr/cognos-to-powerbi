# AI provider selection: azure | claude | copilot | codex | none
COGNOS2PBI_AI_PROVIDER=none

# Path to the provider CLI executable (leave blank to use PATH default)
COGNOS2PBI_CLAUDE_CLI=claude
COGNOS2PBI_COPILOT_CLI=copilot
COGNOS2PBI_CODEX_CLI=codex

# Azure OpenAI (used when COGNOS2PBI_AI_PROVIDER=azure). Auth defaults to Microsoft Entra ID
# (run az login); set COGNOS2PBI_AOAI_API_KEY to use key auth instead. All values are optional.
COGNOS2PBI_AOAI_ENDPOINT=https://gmadbheal-aoai-nuez2i.openai.azure.com/
COGNOS2PBI_AOAI_DEPLOYMENT=gpt-5.4
COGNOS2PBI_AOAI_API_VERSION=2024-10-21
# COGNOS2PBI_AOAI_API_KEY=

# Timeout in seconds for a single AI refinement call
COGNOS2PBI_AI_TIMEOUT=120
